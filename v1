  const ins = state.ins, time = state.time;
  if(ins==='medicaid'){
    const route = time==='today'
      ? 'A copay card won\'t work. The realistic same-day move is a cash discount card; then look into in-state Medicaid or a PAP for the longer term.'
      : 'A copay card won\'t work. Best paths: help the patient apply for Medicaid in your state, or start a manufacturer Patient Assistance Program.';
    return callout('Medicaid across state lines', 'Medicaid generally only covers prescriptions filled <strong>in the state that issued it</strong> (except true emergencies). '+route, 'warn');
  }
  if(ins==='uninsured' && time==='wait'){
    return callout('Strongest option', 'For uninsured patients with a little time, a manufacturer <strong>Patient Assistance Program</strong> often provides the drug free — it just takes an application.');
  }
  if(ins==='medicare'){
    return callout('Note on Medicare', 'Copay cards can\'t be used. Look at charity copay foundations, <strong>Extra Help / Low-Income Subsidy</strong>, a manufacturer PAP, or comparing a cash discount price against the plan copay.');
  }
  return '';
}

// ---- drug lookup (uses the timing choice to order results) ----
function renderDrug(){
  const term = (document.getElementById('q').value||'').trim().toLowerCase();
  const box = document.getElementById('drugResult');
  if(!term){ box.innerHTML=''; return; }

  const note = special(); // situation-specific guidance, shown with the final results
  const hits = DRUGS.filter(d=>{
    const hay = [d.name, d.generic, ...(d.aliases||[])].join(' ').toLowerCase();
    return hay.includes(term);
  });

  if(hits.length===0){
    box.innerHTML = note + callout('No match yet',
      'This drug isn\'t seeded yet — but the search tools under <strong>Other Resources</strong> (NeedyMeds, Medicine Assistance Tool) cover almost any medication. You can also add it to this tool in a couple of minutes; see the note at the bottom of the page.');
    return;
  }

  box.innerHTML = note + hits.map(d=>{
    // When "today" is chosen, float the instant programs to the top.
    let progs = d.programs.slice();
    if(state.time==='today'){
      progs.sort((a,b)=> (a.speed==='instant'?0:1) - (b.speed==='instant'?0:1));
    }
    const list = progs.map(p=>{
      const whoLabel = INS_LABELS[p.who] || p.who;
      const whoTxt = p.who==='any' ? 'anyone' : 'for '+whoLabel;
      const speedBadge = p.speed==='instant'
        ? '<span class="badge b-instant">works today</span>'
        : '<span class="badge b-slow">ready in a few days</span>';
      return `<div class="prog">
        <h3>${p.title}</h3>
        <span class="badge b-info">${whoTxt}</span>${speedBadge}
        <p>${p.desc}</p>
        ${(p.links||(p.link?[{label:'Open official page',url:p.link}]:[])).map(l=>`<a href="${l.url}" target="_blank" rel="noopener">${l.label} →</a>`).join(' &nbsp;·&nbsp; ')}
      </div>`;
    }).join('');
    return `<div class="card">
      <h2>${d.name} <span class="muted small">(${d.generic})</span></h2>
      <p class="muted">${d.use}</p>
      ${list}
    </div>`;
  }).join('');
}

// ---- Other Resources hub ----
function renderHub(){
  document.getElementById('hub').innerHTML = RESOURCES.map(g=>{
    const items = g.items.map(it=>`
      <div class="prog"><h3>${it.title}</h3><p>${it.desc}</p>
      <a href="${it.link}" target="_blank" rel="noopener">Open →</a></div>`).join('');
    return `<div class="card"><h2>${g.group}</h2>${items}</div>`;
  }).join('');
}
renderHub();

// blue/orange note boxes
function callout(title, body, kind){
  return `<div class="callout ${kind==='warn'?'warn':''}"><strong>${title}.</strong> ${body}</div>`;
}
</script>
