const INS_LABELS = {
  commercial:"commercial/employer", medicare:"Medicare", medicaid:"Medicaid",
  uninsured:"uninsured", unsure:"unsure", any:"anyone"
};

const state = { ins:"", time:"" };

// ---- Tabs ----
const tabs = document.querySelectorAll('nav [role=tab]');
tabs.forEach(btn=>btn.addEventListener('click',()=>{
  tabs.forEach(b=>b.setAttribute('aria-selected', b===btn));
  document.querySelectorAll('.panel').forEach(p=>p.classList.remove('active'));
  document.getElementById(btn.dataset.tab).classList.add('active');
}));

// ---- Node 1: insurance ----
document.getElementById('ins').addEventListener('change', e=>{
  state.ins = e.target.value;
  renderFlow();
});

// ---- Node 2: timing ----
document.querySelectorAll('.choice').forEach(btn=>{
  btn.addEventListener('click',()=>{
    state.time = btn.dataset.time;
    document.querySelectorAll('.choice').forEach(b=>b.setAttribute('aria-pressed', b===btn));
    renderFlow();
  });
});

// ---- Node 3: drug search ----
document.getElementById('q').addEventListener('input', renderDrug);

// Show/hide each step as the patient's answers come in.
function renderFlow(){
  const step2 = document.getElementById('step2');
  const step3 = document.getElementById('step3');

  if(!state.ins){
    step2.classList.add('hidden'); step3.classList.add('hidden');
    document.getElementById('drugResult').innerHTML='';
    return;
  }
  step2.classList.remove('hidden');

  if(!state.time){
    step3.classList.add('hidden');
    document.getElementById('drugResult').innerHTML='';
    return;
  }
  step3.classList.remove('hidden');
  renderDrug(); // results — and the situation note — appear here at the end
}



